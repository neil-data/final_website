# GROQ_API_KEY: Required for Groq AI API calls (chatbot).
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# BACKEND_URL: URL of your Python FastAPI backend (api_server.py).
# Used when connecting frontend to live traffic data.
BACKEND_URL="http://localhost:8000"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"
